{
  "name": "nam-bot",
  "version": "0.4.5-rc.2",
  "description": "Neural Amp Modeler Training Manager",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:local": "npm run build && electron-builder --win --config electron-builder.yml --config.win.signAndEditExecutable=false"
  },
  "build": {
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false
  },
  "keywords": [
    "electron",
    "nam",
    "neural-amp-modeler",
    "audio",
    "machine-learning"
  ],
  "author": "Dave Otero",
  "repository": {
    "type": "git",
    "url": "https://github.com/daveotero/nam-bot.git"
  },
  "homepage": "https://github.com/daveotero/nam-bot#readme",
  "bugs": {
    "url": "https://github.com/daveotero/nam-bot/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "electron-log": "^5.4.3",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "rehype-prism-plus": "^2.0.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  }
}
